msgstr "Неозаглавен"

msgid "Very strong"
msgstr "Много силно"

msgid "Very weak"
msgstr "Много слаб"

msgid "Warning! Some data is unsaved"
msgstr "Внимание! Някои данни не са запазени"

msgid "Weak"
